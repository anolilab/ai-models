{
    "name": "ai-models",
    "private": true,
    "type": "module",
    "workspaces": [
        "web",
        "packages/*"
    ],
    "scripts": {
        "build": "nx run-many --target=build --all --parallel",
        "build:affected:packages": "nx affected --target=build --nxBail",
        "build:affected:prod:packages": "nx affected --target=build:prod --nxBail",
        "build:packages": "nx run-many --target=build --parallel --projects=tag:type:package",
        "build:packages:prod": "nx run-many --target=build:prod --parallel --projects=tag:type:package",
        "clean": "nx graph --file=/tmp/discardgraph.json 2>/dev/null && nx run-many --target=clean --all --parallel && rimraf ./node_modules && pnpm run cleanup:empty-packages",
        "cleanup:empty-packages": "node scripts/cleanup-empty-packages.js",
        "dev:web": "nx run web:dev",
        "generate:labeler": "node scripts/generate-labeler-config.js",
        "preinstall": "node -e \"if(process.env.CI == 'true') {console.info('Skipping preinstall...')} else {process.exit(1)}\" || (node verify-node-version.js && npm -y exec only-allow pnpm)",
        "postinstall": "(is-ci || husky || exit 0) && node scripts/generate-jsr-config.js && node scripts/generate-labeler-config.js",
        "lint": "pnpm run lint:prettier && pnpm run lint:eslint && lint:dedupe --check",
        "lint:affected:attw": "nx affected --target=lint:attw --parallel --exclude=*-bench,storybook --nxBail",
        "lint:affected:eslint": "nx affected --target=lint:eslint --parallel --exclude=*-bench,storybook --nxBail",
        "lint:affected:eslint:fix": "nx affected --target=lint:eslint:fix --parallel --exclude=*-bench,storybook --nxBail",
        "lint:affected:package-json": "nx affected --target=lint:package-json --parallel --exclude=*-bench,storybook --nxBail",
        "lint:affected:types": "nx affected --target=lint:types --parallel --exclude=*-bench,storybook --nxBail",
        "lint:attw": "nx graph --file=/tmp/discardgraph.json 2>/dev/null && nx run-many --target=lint:attw --all --parallel",
        "lint:eslint": "nx graph --file=/tmp/discardgraph.json 2>/dev/null && nx run-many --target=lint:eslint --all --parallel",
        "lint:eslint:fix": "nx graph --file=/tmp/discardgraph.json 2>/dev/null && nx run-many --target=lint:eslint:fix --all --parallel",
        "lint:fix": "pnpm run lint:prettier:fix && pnpm run lint:eslint:fix && pnpm run sort-package-json",
        "lint:package-json": "nx graph --file=/tmp/discardgraph.json 2>/dev/null && nx run-many --target=lint:package-json --parallel --projects=tag:type:package",
        "lint:prettier": "pnpm run lint:prettier:root && nx graph --file=/tmp/discardgraph.json 2>/dev/null && nx run-many --target=lint:prettier --all --parallel",
        "lint:prettier:fix": "pnpm run lint:prettier:fix:root && nx graph --file=/tmp/discardgraph.json 2>/dev/null && nx run-many --target=lint:prettier:fix --all --parallel",
        "lint:prettier:fix:root": "prettier --config=.prettierrc.cjs --write '*.{json,yml,yaml,js,mjs,cjs,ts}' && prettier --config=.prettierrc.cjs --write 'scripts/**/*.{json,yml,yaml,js,mjs,cjs,ts}'",
        "lint:prettier:root": "prettier --config=.prettierrc.cjs --check '*.{json,yml,yaml,js,mjs,cjs,ts}' && prettier --config=.prettierrc.cjs --check 'scripts/**/*.{json,yml,yaml,js,mjs,cjs,ts}'",
        "lint:secrets": "secretlint **/*",
        "lint:staged": "lint-staged --verbose --concurrent false --debug",
        "lint:text": "textlint ./.github/ ./packages/** ./README.md ./UPGRADE.md --parallel --experimental --cache --dry-run",
        "lint:text:fix": "textlint ./.github/ ./packages/** ./README.md ./UPGRADE.md --parallel --experimental --fix",
        "lint:types": "nx graph --file=/tmp/discardgraph.json 2>/dev/null && nx run-many --target=lint:types --all --parallel",
        "nx": "nx",
        "nx:graph": "nx graph",
        "sort-package-json": "sort-package-json packages/**/package.json web/**/package.json ./package.json",
        "test": "nx graph --file=/tmp/discardgraph.json 2>/dev/null && nx run-many --target=test --all --parallel",
        "test:affected": "nx affected --target=test --parallel --exclude=*-bench,shared-utils --nxBail",
        "test:affected:browser:chrome": "nx affected --target=test:browser:chrome --parallel --exclude=*-bench,shared-utils --nxBail",
        "test:affected:browser:firefox": "nx affected --target=test:browser:firefox --parallel --exclude=*-bench,shared-utils --nxBail",
        "test:affected:browser:webkit": "nx affected --target=test:browser:webkit --parallel --exclude=*-bench,shared-utils --nxBail",
        "test:affected:coverage": "nx affected --target=test:coverage --parallel --exclude=*-bench,shared-utils --nxBail",
        "test:coverage": "nx graph --file=/tmp/discardgraph.json 2>/dev/null && nx run-many --target=test:coverage --all --parallel",
        "test:e2e": "nx run web:test:e2e"
    },
    "dependencies": {
        "@anolilab/commitlint-config": "^9.1.1",
        "@anolilab/lint-staged-config": "^6.0.1",
        "@anolilab/multi-semantic-release": "^4.1.1",
        "@anolilab/prettier-config": "^9.1.1",
        "@commitlint/cli": "^20.4.4",
        "@commitlint/config-conventional": "^20.4.4",
        "@nrwl/tao": "19.8.4",
        "@nrwl/workspace": "19.8.4",
        "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
        "@types/node": "25.3.3",
        "commitizen": "^4.3.1",
        "husky": "^9.1.7",
        "is-ci": "^4.1.0",
        "lint-staged": "^16.3.1",
        "nx": "^22.5.3",
        "pkg-pr-new": "^0.0.65",
        "prettier": "3.8.1",
        "rimraf": "6.1.3",
        "secretlint": "11.3.1",
        "semantic-release": "^25.0.3",
        "sort-package-json": "^3.6.1"
    },
    "packageManager": "pnpm@10.30.3",
    "nx": {
        "includedScripts": [],
        "affected": {
            "defaultBase": "main"
        }
    }
}
